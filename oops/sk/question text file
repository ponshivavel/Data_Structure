Print only even numbers from the stack without modifying it.
import java.util.*;
public  class stack {
    public static void main(String []arg){
        Scanner in = new Scanner(System.in);
        Stack<Integer> sk = new Stack<>();
        for(int i =0;i<20;i++){
            sk.push(i);
        }
        int n = sk.size();
        for(int i =0;i<n;i++){
                if(sk.get(i)%2==0) System.out.print(sk.get(i)+" ");
        }
    
    }
    
}
