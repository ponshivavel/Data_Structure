Push numbers 1 to 5 and print the stack.

import java.util.*;
public  class stack {
    public static void main(String []arg){
        Scanner in = new Scanner(System.in);
        Stack<Integer> sk = new Stack<>();
        for(int i =0;i<5;i++){
            sk.push(in.nextInt());
        }
        System.out.print(sk);
    }
    
}

